# Alpha Vantage API key (required)
# Get yours at: https://www.alphavantage.co/support/#api-key
# Endpoints used:
#   - TOP_GAINERS_LOSERS (1 call) — finds today's biggest losers
#   - OVERVIEW (up to 5 calls) — gets P/E, 52-week low/high, sector, analyst targets
# Free tier: 25 requests/day, 5 requests/minute
ALPHA_VANTAGE_API_KEY=your_key_here

# Brave Search API key (optional — news context will be skipped if not set)
# Get yours at: https://brave.com/search/api/
# Endpoint used:
#   - /res/v1/news/search (1 call per passing stock) — fetches recent headlines
BRAVE_API_KEY=your_key_here

# Telegram chat ID (required for Telegram delivery)
# To find yours: message your OpenClaw bot on Telegram, then run:
#   openclaw message read --channel telegram --limit 1 --json
# Look for the chat.id number in the output
TELEGRAM_TARGET=
